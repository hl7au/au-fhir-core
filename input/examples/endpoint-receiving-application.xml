<!--  AU Core Endpoint - HL7 V2 Receiving Application example -->
<Endpoint xmlns="http://hl7.org/fhir">
  <id value="endpoint-receiving-application"/>
  <meta>
    <profile value="http://hl7.org.au/fhir/StructureDefinition/au-core-endpoint"/>
  </meta>
  <text>
    <status value="generated"/>
    <div xmlns="http://www.w3.org/1999/xhtml">
      <p><b>Generated Narrative</b></p>
      <p>Example showing au-receivingapplication extension - HL7 V2 receiving application identifier</p>
    </div>
  </text>

  <!-- au-receivingapplication extension: Identifies the application receiving HL7 V2 messages -->
  <extension url="http://hl7.org.au/fhir/StructureDefinition/au-receivingapplication">
    <valueString value="EPIC"/>
  </extension>

  <identifier>
    <system value="http://example.org/endpoint-identifiers"/>
    <value value="epic-hl7v2-endpoint"/>
  </identifier>
  <status value="active"/>
  <connectionType>
    <system value="http://terminology.hl7.org/CodeSystem/endpoint-connection-type"/>
    <code value="hl7v2-mllp"/>
    <display value="HL7 v2 MLLP"/>
  </connectionType>
  <name value="Epic EMR System HL7 V2 Endpoint"/>
  <managingOrganization>
    <reference value="Organization/melbourne-health"/>
    <display value="Melbourne Health"/>
  </managingOrganization>
  <payloadType>
    <coding>
      <system value="http://terminology.hl7.org/CodeSystem/v2-0003"/>
      <code value="ORU"/>
      <display value="Observation Result"/>
    </coding>
  </payloadType>
  <payloadType>
    <coding>
      <system value="http://terminology.hl7.org/CodeSystem/v2-0003"/>
      <code value="ORM"/>
      <display value="Order Message"/>
    </coding>
  </payloadType>
  <payloadMimeType value="application/hl7-v2"/>
  <address value="mllp://epic.mh.org.au:8080"/>
</Endpoint>