<!--  AU Core Endpoint - Environment Type example -->
<Endpoint xmlns="http://hl7.org/fhir">
  <id value="endpoint-environment-type"/>
  <meta>
    <profile value="http://hl7.org.au/fhir/StructureDefinition/au-core-endpoint"/>
  </meta>
  <text>
    <status value="generated"/>
    <div xmlns="http://www.w3.org/1999/xhtml">
      <p><b>Generated Narrative</b></p>
      <p>Example showing au-environmenttype extension - Multiple environment types for this endpoint</p>
    </div>
  </text>

  <!-- au-environmenttype extensions: Can specify multiple environment types -->
  <extension url="http://hl7.org.au/fhir/StructureDefinition/au-environmenttype">
    <valueCode value="production"/>
  </extension>
  <extension url="http://hl7.org.au/fhir/StructureDefinition/au-environmenttype">
    <valueCode value="clinical"/>
  </extension>
  <extension url="http://hl7.org.au/fhir/StructureDefinition/au-environmenttype">
    <valueCode value="secure"/>
  </extension>

  <identifier>
    <system value="http://example.org/endpoint-identifiers"/>
    <value value="secure-clinical-fhir-endpoint"/>
  </identifier>
  <status value="active"/>
  <connectionType>
    <system value="http://terminology.hl7.org/CodeSystem/endpoint-connection-type"/>
    <code value="hl7-fhir-rest"/>
    <display value="HL7 FHIR"/>
  </connectionType>
  <name value="Secure Clinical Data FHIR Endpoint"/>
  <managingOrganization>
    <reference value="Organization/western-health"/>
    <display value="Western Health"/>
  </managingOrganization>
  <payloadType>
    <coding>
      <system value="http://hl7.org/fhir/resource-types"/>
      <code value="Patient"/>
      <display value="Patient"/>
    </coding>
  </payloadType>
  <payloadType>
    <coding>
      <system value="http://hl7.org/fhir/resource-types"/>
      <code value="DiagnosticReport"/>
      <display value="Diagnostic Report"/>
    </coding>
  </payloadType>
  <payloadMimeType value="application/fhir+json"/>
  <address value="https://secure-fhir.westernhealth.org.au/R4"/>
</Endpoint>